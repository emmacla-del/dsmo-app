          <td>{{formatCell dismissals.female}}</td>
          <td>{{formatCell dismissals.total}}</td>
          <td>{{formatCell resignations.male}}</td>
          <td>{{formatCell resignations.female}}</td>
          <td>{{formatCell resignations.total}}</td>
          <td>{{formatCell retirements.male}}</td>
          <td>{{formatCell retirements.female}}</td>
          <td>{{formatCell retirements.total}}</td>
          <td>{{formatCell others.male}}</td>
          <td>{{formatCell others.female}}</td>
          <td>{{formatCell others.total}}</td>
          <td>{{formatCell ensemble.male}}</td>
          <td>{{formatCell ensemble.female}}</td>
          <td>{{formatCell ensemble.total}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <p class="qtitle">S3Q02 : Quels sont les principaux motifs de licenciement ? / What are the main grounds for
      dismissal?</p>
    {{! Mapper must provide exactly 3 items with index 1,2,3 }}
