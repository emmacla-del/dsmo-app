      <thead>
        <tr>
          <th rowspan="2" style="width:14%">CSP / SPC</th>
          <th colspan="3" class="th2">Licenciements / Dismissal</th>
          <th colspan="3" class="th2">Démissions / Resignation</th>
          <th colspan="3" class="th2">Départ à la retraite / Retirement</th>
          <th colspan="3" class="th2">Autres départs / Other departure</th>
          <th colspan="3" class="th3">Ensemble / Whole</th>
