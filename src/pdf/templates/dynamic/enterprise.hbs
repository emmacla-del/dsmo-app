          <td class="desc">{{domain}}</td>
          <td>{{formatCell male}}</td>
          <td>{{formatCell female}}</td>
          <td>{{formatCell total}}</td>
        </tr>
        {{/each}}
        <tr class="tr-total">
          <td class="idx"></td>
          <td class="lh">Total</td>
          <td>{{formatCell trainingNeedsTotals.male}}</td>
          <td>{{formatCell trainingNeedsTotals.female}}</td>
          <td>{{formatCell trainingNeedsTotals.total}}</td>
        </tr>
      </tbody>
    </table>

    {{! S3Q03 moved to end of page 6 per PDF layout }}
    <p class="qtitle">S3Q03 : Combien de personnes avez-vous licenci&eacute;es ou mises en ch&ocirc;mage technique du
      1er Janvier {{surveyYear}} &agrave; ce jour ?</p>
    {{> dismissalTechTable rows=dismissalTechUnemploymentRows totals=dismissalTechUnemploymentTotals}}
  </div>

