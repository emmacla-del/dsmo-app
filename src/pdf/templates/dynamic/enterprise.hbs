{{! ONEFOP — Questionnaire Entreprise — matched to pdf-data-mapper.service.ts }}
{{! REQUIRED HANDLEBARS HELPERS: eq, formatCell }}
{{#with this}}
<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8" />
  <title>ONEFOP Entreprise {{surveyYear}}</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8pt;
      color: #000;
      background: #fff
    }

    .page {
      width: 210mm;
      min-height: 297mm;
      padding: 8mm 10mm;
      page-break-after: always
    }

    .page:last-child {
      page-break-after: auto
    }

    .hdr {
      display: flex;
      align-items: center;
      border: 2px solid #003366;
      margin-bottom: 4mm
    }

    .hdr-logo {
      width: 28mm;
      padding: 2mm;
      border-right: 2px solid #003366;
      flex-shrink: 0
    }

    .hdr-logo img {
      width: 100%;
      display: block
    }

    .hdr-logo-blank {
      width: 28mm;
      height: 16mm;
      border-right: 2px solid #003366;
      flex-shrink: 0
    }

    .hdr-title {
      flex: 1;
      text-align: center;
      padding: 2mm 3mm
    }

    .hdr-title h1 {
      font-size: 9.5pt;
      font-weight: bold;
      color: #003366;
      line-height: 1.3
    }

    .hdr-title h2 {
      font-size: 8pt;
      margin-top: 1mm
    }

    .hdr-meta {
      padding: 2mm 3mm;
      border-left: 2px solid #003366;
      font-size: 8pt;
      white-space: nowrap
    }

    .sec {
      background: #003366;
      color: #fff;
      font-weight: bold;
      font-size: 8.5pt;
      padding: 2px 5px;
      margin: 3mm 0 2mm
    }

    .subsec {
      font-weight: bold;
      font-size: 8.5pt;
      margin: 3mm 0 1mm;
      border-bottom: 1px solid #003366;
      padding-bottom: 1px
    }

    .qtitle {
      font-weight: bold;
      margin-bottom: 1mm;
      font-size: 8pt
    }

    .qrow {
      display: flex;
      align-items: baseline;
      margin-bottom: 1.5mm;
      gap: 2mm
    }

    .qcode {
      font-size: 7pt;
      font-weight: bold;
      color: #555;
      min-width: 11mm;
      flex-shrink: 0
    }

    .qlabel {
      font-size: 8pt;
      flex-shrink: 0
    }

    .qval {
      border-bottom: 1px solid #555;
      flex: 1;
      min-height: 4mm;
      padding: 0 1mm;
      font-size: 8pt
    }

    .qval-sm {
      border-bottom: 1px solid #555;
      min-width: 25mm;
      min-height: 4mm;
      padding: 0 1mm;
      font-size: 8pt
    }

    .qval-lg {
      border-bottom: 1px solid #555;
      min-width: 50mm;
      min-height: 4mm;
      padding: 0 1mm;
      font-size: 8pt
    }

    .box {
      display: inline-block;
      width: 4mm;
      height: 4mm;
      border: 1px solid #000;
      text-align: center;
      line-height: 3.5mm;
      font-size: 7pt;
      margin: 0 0.5mm
    }

    .box-group {
      display: inline-flex;
      gap: 1mm;
      align-items: center
    }

    .cbg {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5mm 5mm;
      margin: 0 0 1.5mm 13mm;
      font-size: 8pt
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 3mm;
      font-size: 7pt
    }

    th {
      background: #003366;
      color: #fff;
      text-align: center;
      padding: 2px;
      border: 1px solid #888;
      font-size: 6.5pt;
      line-height: 1.2
    }

    th.th2 {
      background: #1a5276
    }

    th.th3 {
      background: #2e86c1
    }

    td {
      border: 1px solid #bbb;
      text-align: center;
      padding: 1px 2px;
      font-size: 7pt
    }

    td.lh {
      text-align: left;
      background: #eaf0f8;
      font-weight: bold;
      padding-left: 3px
    }

    td.lh2 {
      text-align: left;
      background: #d6e4f0;
      padding-left: 8px
    }

    tr.tr-total td {
      background: #d0e4f0;
      font-weight: bold
    }

    .list-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 3mm;
      font-size: 7.5pt
    }

    .list-table th {
      background: #003366;
      color: #fff;
      padding: 2px 4px;
      border: 1px solid #888
    }

    .list-table td {
      border: 1px solid #ccc;
      padding: 2px 4px
    }

    .list-table td.idx {
      background: #eaf0f8;
      font-weight: bold;
      width: 8mm;
      text-align: center
    }

    .list-table td.desc {
      text-align: left
    }

    @media print {
      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact
      }
    }
  </style>
</head>

<body>

  {{! ══════════ PAGE 1 — S0 + S1 ══════════ }}
  <div class="page">
    <div class="hdr">
      {{#if logoBase64}}<div class="hdr-logo"><img src="{{logoBase64}}" alt="ONEFOP" /></div>
      {{else}}<div class="hdr-logo-blank"></div>{{/if}}
      <div class="hdr-title">
        <h1>ENQU&Ecirc;TE SUR L'EMPLOI ET LA FORMATION PROFESSIONNELLE<br />Survey on Employment and Vocational Training
        </h1>
        <h2>Questionnaire &mdash; ENTREPRISE / ENTERPRISE</h2>
      </div>
      <div class="hdr-meta"><strong>Ann&eacute;e / Year :</strong> {{surveyYear}}<br />Copie / Copy : {{copy}}</div>
    </div>

    <div class="sec">SECTION 0 &mdash; IDENTIFICATION DU R&Eacute;PONDANT / IDENTIFICATION OF RESPONDENT</div>

    <div class="qrow"><span class="qcode">S0Q01</span><span class="qlabel">Noms et pr&eacute;noms du r&eacute;pondant /
        Respondent's full name :</span><span class="qval">{{respondentName}}</span></div>
    <div class="qrow"><span class="qcode">S0Q02</span><span class="qlabel">Fonction du r&eacute;pondant / Respondent's
        function :</span><span class="qval">{{respondentFunction}}</span></div>
    <div class="qrow"><span class="qcode">S0Q03</span><span class="qlabel">Contacts r&eacute;pondant / Respondent's
        contacts :</span></div>
    <div class="qrow" style="margin-left:13mm">
      <span class="qlabel">T&eacute;l 1 :</span><span class="qval-sm">{{respondentPhone1}}</span>
      <span class="qlabel" style="margin-left:4mm">T&eacute;l 2 :</span><span
        class="qval-sm">{{respondentPhone2}}</span>
    </div>
    <div class="qrow" style="margin-left:13mm"><span class="qlabel">E-mail :</span><span
        class="qval">{{respondentEmail}}</span></div>

    <div class="sec">SECTION 1 &mdash; IDENTIFICATION DE L'ENTREPRISE / COMPANY DETAILS</div>

    <div class="qrow"><span class="qcode">S1Q01</span><span class="qlabel">Quel est le r&eacute;gime/statut juridique de
        votre institution / What is the legal status of your institution ?</span></div>
    <div class="cbg">
      <span>{{#if (eq legalStatus 1)}}&#9745;{{else}}&#9744;{{/if}} (1) Soci&eacute;t&eacute; unipersonnelle /
        Single-member company</span>
      <span>{{#if (eq legalStatus 2)}}&#9745;{{else}}&#9744;{{/if}} (2) SARL / LLC</span>
      <span>{{#if (eq legalStatus 3)}}&#9745;{{else}}&#9744;{{/if}} (3) SA / PLC</span>
      <span>{{#if (eq legalStatus 4)}}&#9745;{{else}}&#9744;{{/if}} (4) Autres / Others</span>
      <span class="box">{{legalStatus}}</span>
    </div>

    <div class="qrow"><span class="qcode">S1Q02</span><span class="qlabel">Nom de l'entreprise / Company name
        :</span><span class="qval">{{companyName}}</span></div>

    <div class="qrow"><span class="qcode">S1Q03</span><span class="qlabel">Milieu de r&eacute;sidence / Area :</span>
      <span style="margin-right:6mm">{{#if (eq area 1)}}&#9745;{{else}}&#9744;{{/if}} (1) Urbain / Urban</span>
      <span>{{#if (eq area 2)}}&#9745;{{else}}&#9744;{{/if}} (2) Rural / Rural</span>
      <span class="box" style="margin-left:3mm">{{area}}</span>
    </div>

    <div class="qrow"><span class="qcode">S1Q04</span><span class="qlabel">R&eacute;gion / Region :</span><span
        class="qval-sm">{{region}}</span>
      <span class="qval-sm" style="min-width:12mm;text-align:center">{{region}}</span>
      <span class="qlabel" style="margin-left:3mm">D&eacute;partement / Division :</span><span
        class="qval-sm">{{department}}</span>
      <span class="qval-sm" style="min-width:12mm;text-align:center">{{department}}</span>
    </div>
    <div class="qrow" style="margin-left:13mm">
      <span class="qlabel">Arrondissement / Subdivision :</span><span class="qval-sm">{{subdivision}}</span>
      <span class="qval-sm" style="min-width:18mm;text-align:center">{{subdivision}}</span>
      <span class="qlabel" style="margin-left:3mm">Quartier/Village/Localit&eacute; / Neighborhood/Village/Locality
        :</span><span class="qval">{{locality}}</span>
    </div>

    <div class="qrow"><span class="qcode">S1Q05</span><span class="qlabel">T&eacute;l 1 / Tel 1 :</span><span
        class="qval-sm">{{phone1}}</span>
      <span class="qlabel" style="margin-left:4mm">T&eacute;l 2 / Tel 2 :</span><span class="qval-sm">{{phone2}}</span>
      <span class="qlabel" style="margin-left:4mm">BP / PO Box :</span><span class="qval-sm">{{poBox}}</span>
    </div>

    <div class="qrow"><span class="qcode">S1Q06</span><span class="qlabel">Secteur d'activit&eacute; / Business sector
        :</span>
      <span style="margin-right:6mm">{{#if (eq businessSector 1)}}&#9745;{{else}}&#9744;{{/if}} (1) Primaire /
        Primary</span>
      <span style="margin-right:6mm">{{#if (eq businessSector 2)}}&#9745;{{else}}&#9744;{{/if}} (2) Secondaire /
        Secondary</span>
      <span>{{#if (eq businessSector 3)}}&#9745;{{else}}&#9744;{{/if}} (3) Tertiaire / Tertiary</span>
      <span class="box" style="margin-left:3mm">{{businessSector}}</span>
    </div>

    <div class="qrow"><span class="qcode">S1Q07</span><span class="qlabel">Branche d'activit&eacute; / Branch of
        activity :</span><span class="qval">{{branchActivity}}</span></div>
    <div class="qrow"><span class="qcode">S1Q08</span><span class="qlabel">Activit&eacute; principale / Main activity
        :</span><span class="qval">{{mainActivity}}</span></div>
    <div class="qrow"><span class="qcode">S1Q09</span><span class="qlabel">Si&egrave;ge social de l'entreprise /
        Company's head office :</span><span class="qval">{{headOffice}}</span></div>
    <div class="qrow"><span class="qcode">S1Q10</span><span class="qlabel">Nombre d'employ&eacute; permanent / Number of
        permanent workers :</span><span class="qval-sm">{{permanentWorkers}}</span></div>
    <div class="qrow"><span class="qcode">S1Q11</span><span class="qlabel">Nombre de poste vacant / Number of vacancies
        :</span><span class="qval-sm">{{vacancies}}</span></div>
    <div class="qrow"><span class="qcode">S1Q12</span><span class="qlabel">Taille de l'entreprise / Enterprise size
        :</span>
      <span style="margin-right:4mm">{{#if (eq enterpriseSize 1)}}&#9745;{{else}}&#9744;{{/if}} (1) TPE / Very small
        enterprise</span>
      <span style="margin-right:4mm">{{#if (eq enterpriseSize 2)}}&#9745;{{else}}&#9744;{{/if}} (2) PE / Small
        enterprise</span>
      <span style="margin-right:4mm">{{#if (eq enterpriseSize 3)}}&#9745;{{else}}&#9744;{{/if}} (3) ME / Medium-sized
        enterprise</span>
      <span>{{#if (eq enterpriseSize 4)}}&#9745;{{else}}&#9744;{{/if}} (4) GE / Large enterprise</span>
      <span class="box" style="margin-left:3mm">{{enterpriseSize}}</span>
    </div>
  </div>

  {{! ══════════ PAGE 2 — S2.1 + S2.2 ══════════ }}
  <div class="page">
    <div class="sec">SECTION 2 &mdash; EMPLOI ET TRAVAIL / EMPLOYMENT AND LABOUR</div>
    <div class="subsec">2.1 DEMANDE D'EMPLOIS / JOB APPLICATION</div>
    <p class="qtitle">S21Q01 : Combien de demandes d'emplois avez-vous enregistr&eacute; selon la cat&eacute;gorie
      socioprofessionnelle, le sexe et la tranche d'&acirc;ge du 1er Janvier {{surveyYear}} &agrave; ce jour ?</p>
    {{> cspAgeTable rows=jobApplicationsRows totals=jobApplicationsTotals}}

    <div class="subsec">2.2 RECRUTEMENTS / RECRUITMENTS</div>
    <p class="qtitle">S22Q01 : Combien de permanents avez-vous recrut&eacute; selon la cat&eacute;gorie
      socioprofessionnelle, le sexe et la tranche d'&acirc;ge du 1er Janvier {{surveyYear}} &agrave; ce jour ?</p>
    {{> cspAgeTable rows=recruitmentsPermanentRows totals=recruitmentsPermanentTotals}}
    <p class="qtitle">S22Q02 : Combien de temporaires avez-vous recrut&eacute; selon la cat&eacute;gorie
      socioprofessionnelle, le sexe et la tranche d'&acirc;ge du 1er Janvier {{surveyYear}} &agrave; ce jour ?</p>
    {{> cspAgeTable rows=recruitmentsTemporaryRows totals=recruitmentsTemporaryTotals}}
  </div>

  {{! ══════════ PAGE 3 — S2.2 Diploma + Disabled + Vulnerable ══════════ }}
  <div class="page">
    <p class="qtitle">S22Q03 : Combien de personnes avez-vous recrut&eacute; selon la cat&eacute;gorie
      socioprofessionnelle, le sexe, le dipl&ocirc;me et la tranche d'&acirc;ge du 1er Janvier {{surveyYear}} &agrave;
      ce jour ?</p>
    {{> cspAgeTable rows=recruitmentsByDiplomaRows totals=recruitmentsByDiplomaTotals}}

    <p class="qtitle">S22Q04 : Combien de personnes en situation de handicap avez-vous recrut&eacute; selon la
      cat&eacute;gorie socioprofessionnelle, le sexe et le statut du 1er Janvier {{surveyYear}} &agrave; ce jour ?</p>
    {{> permTempTable rows=disabledRecruitmentsRows totals=disabledRecruitmentsTotals}}

    <p class="qtitle">S22Q05 : Combien de personnes vuln&eacute;rables avez-vous recrut&eacute; selon le statut et la
      nature de la vuln&eacute;rabilit&eacute; du 1er Janvier {{surveyYear}} &agrave; ce jour ?</p>
    {{> permTempTable rows=vulnerableRecruitmentsRows totals=vulnerableRecruitmentsTotals}}
  </div>

  {{! ══════════ PAGE 4 — S2.3 First-time Job Seekers ══════════ }}
  <div class="page">
    <div class="subsec">2.3 PRIMO DEMANDEUR (personne &agrave; la recherche de son premier emploi) / FIRST-TIME JOB
      SEEKER</div>
    <p class="qtitle">S23Q01 : Combien de personnes recherchant leur premier emploi avez-vous enregistr&eacute; selon la
      cat&eacute;gorie socioprofessionnelle, le sexe et la tranche d'&acirc;ge du 1er Janvier {{surveyYear}} &agrave; ce
      jour ?</p>
    {{> cspAgeTable rows=firstTimeJobSeekerRows totals=firstTimeJobSeekerTotals}}

    <p class="qtitle">S23Q02 : Combien de personnes travaillant pour la premi&egrave;re fois avez-vous recrut&eacute;es
      selon la cat&eacute;gorie socioprofessionnelle et la tranche d'&acirc;ge du 1er Janvier {{surveyYear}} &agrave; ce
      jour ?</p>
    <table>
      <thead>
        <tr>
          <th rowspan="2" style="width:18%">CSP / SPC</th>
          <th colspan="4" class="th2">Masculin / Male</th>
          <th colspan="4" class="th2">F&eacute;minin / Female</th>
          <th colspan="4" class="th3">TOTAL</th>
        </tr>
        <tr>
          <th class="th2">15-24</th>
          <th class="th2">25-34</th>
          <th class="th2">35+</th>
          <th class="th2">Total</th>
          <th class="th2">15-24</th>
          <th class="th2">25-34</th>
          <th class="th2">35+</th>
          <th class="th2">Total</th>
          <th class="th3">15-24</th>
          <th class="th3">25-34</th>
          <th class="th3">35+</th>
          <th class="th3">Total</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="lh" colspan="13" style="background:#c8d9ea;font-style:italic">Permanent / Permanent</td>
        </tr>
        {{#each s23q02.permanent}}
        <tr>
          <td class="lh2">{{label}}</td>
          <td>{{formatCell male.age15_24}}</td>
          <td>{{formatCell male.age25_34}}</td>
          <td>{{formatCell male.age35plus}}</td>
          <td>{{formatCell male.total}}</td>
          <td>{{formatCell female.age15_24}}</td>
          <td>{{formatCell female.age25_34}}</td>
          <td>{{formatCell female.age35plus}}</td>
          <td>{{formatCell female.total}}</td>
          <td>{{formatCell total.age15_24}}</td>
          <td>{{formatCell total.age25_34}}</td>
          <td>{{formatCell total.age35plus}}</td>
          <td>{{formatCell total.total}}</td>
        </tr>
        {{/each}}
        <tr class="tr-total">
          <td class="lh">{{s23q02.permanentTotals.label}}</td>
          <td>{{formatCell s23q02.permanentTotals.male.age15_24}}</td>
          <td>{{formatCell s23q02.permanentTotals.male.age25_34}}</td>
          <td>{{formatCell s23q02.permanentTotals.male.age35plus}}</td>
          <td>{{formatCell s23q02.permanentTotals.male.total}}</td>
          <td>{{formatCell s23q02.permanentTotals.female.age15_24}}</td>
          <td>{{formatCell s23q02.permanentTotals.female.age25_34}}</td>
          <td>{{formatCell s23q02.permanentTotals.female.age35plus}}</td>
          <td>{{formatCell s23q02.permanentTotals.female.total}}</td>
          <td>{{formatCell s23q02.permanentTotals.total.age15_24}}</td>
          <td>{{formatCell s23q02.permanentTotals.total.age25_34}}</td>
          <td>{{formatCell s23q02.permanentTotals.total.age35plus}}</td>
          <td>{{formatCell s23q02.permanentTotals.total.total}}</td>
        </tr>
        <tr>
          <td class="lh" colspan="13" style="background:#c8d9ea;font-style:italic">Temporaire / Temporary</td>
        </tr>
        {{#each s23q02.temporary}}
        <tr>
          <td class="lh2">{{label}}</td>
          <td>{{formatCell male.age15_24}}</td>
          <td>{{formatCell male.age25_34}}</td>
          <td>{{formatCell male.age35plus}}</td>
          <td>{{formatCell male.total}}</td>
          <td>{{formatCell female.age15_24}}</td>
          <td>{{formatCell female.age25_34}}</td>
          <td>{{formatCell female.age35plus}}</td>
          <td>{{formatCell female.total}}</td>
          <td>{{formatCell total.age15_24}}</td>
          <td>{{formatCell total.age25_34}}</td>
          <td>{{formatCell total.age35plus}}</td>
          <td>{{formatCell total.total}}</td>
        </tr>
        {{/each}}
        <tr class="tr-total">
          <td class="lh">{{s23q02.temporaryTotals.label}}</td>
          <td>{{formatCell s23q02.temporaryTotals.male.age15_24}}</td>
          <td>{{formatCell s23q02.temporaryTotals.male.age25_34}}</td>
          <td>{{formatCell s23q02.temporaryTotals.male.age35plus}}</td>
          <td>{{formatCell s23q02.temporaryTotals.male.total}}</td>
          <td>{{formatCell s23q02.temporaryTotals.female.age15_24}}</td>
          <td>{{formatCell s23q02.temporaryTotals.female.age25_34}}</td>
          <td>{{formatCell s23q02.temporaryTotals.female.age35plus}}</td>
          <td>{{formatCell s23q02.temporaryTotals.female.total}}</td>
          <td>{{formatCell s23q02.temporaryTotals.total.age15_24}}</td>
          <td>{{formatCell s23q02.temporaryTotals.total.age25_34}}</td>
          <td>{{formatCell s23q02.temporaryTotals.total.age35plus}}</td>
          <td>{{formatCell s23q02.temporaryTotals.total.total}}</td>
        </tr>
        <tr class="tr-total">
          <td class="lh">{{s23q02.grandTotals.label}}</td>
          <td>{{formatCell s23q02.grandTotals.male.age15_24}}</td>
          <td>{{formatCell s23q02.grandTotals.male.age25_34}}</td>
          <td>{{formatCell s23q02.grandTotals.male.age35plus}}</td>
          <td>{{formatCell s23q02.grandTotals.male.total}}</td>
          <td>{{formatCell s23q02.grandTotals.female.age15_24}}</td>
          <td>{{formatCell s23q02.grandTotals.female.age25_34}}</td>
          <td>{{formatCell s23q02.grandTotals.female.age35plus}}</td>
          <td>{{formatCell s23q02.grandTotals.female.total}}</td>
          <td>{{formatCell s23q02.grandTotals.total.age15_24}}</td>
          <td>{{formatCell s23q02.grandTotals.total.age25_34}}</td>
          <td>{{formatCell s23q02.grandTotals.total.age35plus}}</td>
          <td>{{formatCell s23q02.grandTotals.total.total}}</td>
        </tr>
      </tbody>
    </table>
  </div>

  {{! ══════════ PAGE 5 — S3 Departures (Q01 + Q02) ══════════ }}
  <div class="page">
    <div class="sec">SECTION 3 &mdash; D&Eacute;PARTS / DEPARTURES</div>
    <p class="qtitle">S3Q01 : Combien de d&eacute;parts avez-vous enregistr&eacute;s du 1er Janvier {{surveyYear}}
      &agrave; ce jour ?</p>
    {{> departuresTable rows=departuresRows totals=departuresTotals}}

    <p class="qtitle">S3Q02 : Quels sont les principaux motifs de licenciement ? / What are the main grounds for
      dismissal?</p>
    <table class="list-table">
      <thead>
        <tr>
          <th style="width:8mm">#</th>
          <th style="text-align:left">Motif / Reason</th>
          <th style="width:14mm">M</th>
          <th style="width:14mm">F</th>
          <th style="width:14mm">Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each dismissalReasons}}
        <tr>
          <td class="idx">{{index}}</td>
          <td class="desc">{{text}}</td>
          <td>{{formatCell male}}</td>
          <td>{{formatCell female}}</td>
          <td>{{formatCell total}}</td>
        </tr>
        {{/each}}
        <tr class="tr-total">
          <td class="idx"></td>
          <td class="lh">Total</td>
          <td>{{formatCell dismissalReasonsTotals.male}}</td>
          <td>{{formatCell dismissalReasonsTotals.female}}</td>
          <td>{{formatCell dismissalReasonsTotals.total}}</td>
        </tr>
      </tbody>
    </table>
  </div>

  {{! ══════════ PAGE 6 — S4 Training + S3Q03 ══════════ }}
  <div class="page">
    <div class="sec">SECTION 4 &mdash; STAGE ET FORMATION / INTERNSHIP AND TRAINING</div>
    <p class="qtitle">S4Q01 : Combien de stagiaires avez-vous recrut&eacute;s du 1er Janvier {{surveyYear}} &agrave; ce
      jour ?</p>
    {{> simpleTable rows=internshipsRows totals=internshipsTotals}}

    <p class="qtitle">S4Q02 : Quels sont les besoins en comp&eacute;tence de votre entreprise ? (3 priorit&eacute;s)</p>
    <table class="list-table">
      <thead>
        <tr>
          <th style="width:8mm">#</th>
          <th style="text-align:left">Comp&eacute;tence / Skill</th>
          <th style="width:14mm">M</th>
          <th style="width:14mm">F</th>
          <th style="width:14mm">Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each skills}}
        <tr>
          <td class="idx">{{index}}</td>
          <td class="desc">{{description}}</td>
          <td>{{formatCell male}}</td>
          <td>{{formatCell female}}</td>
          <td>{{formatCell total}}</td>
        </tr>
        {{/each}}
        <tr class="tr-total">
          <td class="idx"></td>
          <td class="lh">Total</td>
          <td>{{formatCell skillsTotals.male}}</td>
          <td>{{formatCell skillsTotals.female}}</td>
          <td>{{formatCell skillsTotals.total}}</td>
        </tr>
      </tbody>
    </table>

    <p class="qtitle">S4Q03 : Quels sont les besoins en formation des personnels ? (3 priorit&eacute;s)</p>
    <table class="list-table">
      <thead>
        <tr>
          <th style="width:8mm">#</th>
          <th style="text-align:left">Domaine de formation</th>
          <th style="width:14mm">M</th>
          <th style="width:14mm">F</th>
          <th style="width:14mm">Total</th>
        </tr>
      </thead>
      <tbody>
