      </tbody>
    </table>

  </div>

  <script>
    // Fill digit boxes from data-val attribute on .ph-box elements
    // Cameroon phones = 9 digits
    document.querySelectorAll('.ph-box[data-val]').forEach(function (row) {
      var val = (row.getAttribute('data-val') || '').replace(/\D/g, '');
      var boxes = row.querySelectorAll('.pd');
      boxes.forEach(function (box, i) {
        box.textContent = val.charAt(i) || '';
      });
    });
  </script>
</body>

</html>
{{/with}}