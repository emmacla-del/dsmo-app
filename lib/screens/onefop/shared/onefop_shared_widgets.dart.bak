// lib/screens/onefop/shared/onefop_shared_widgets.dart
import 'package:flutter/material.dart';
import 'package:google_fonts/google_fonts.dart';

// ── Design tokens ─────────────────────────────────────────────────────────────
class OnefopColors {
  static const bg = Color(0xFF0B1120);
  static const surface = Color(0xFF141E30);
  static const card = Color(0xFF1A2540);
  static const border = Color(0x18FFFFFF);
  static const teal = Color(0xFF00C896);
  static const blue = Color(0xFF3B82F6);
  static const rose = Color(0xFFFF4D6D);
  static const gold = Color(0xFFE8A000);
  static const white = Color(0xFFFFFFFF);
  static const white70 = Color(0xB3FFFFFF);
  static const white60 = Color(0x99FFFFFF);
  static const white40 = Color(0x66FFFFFF);
  static const white20 = Color(0x33FFFFFF);
  static const white10 = Color(0x1AFFFFFF);
}

TextStyle mono(double size,
        {Color color = OnefopColors.white70,
        FontWeight weight = FontWeight.normal}) =>
    TextStyle(
        fontFamily: 'SpaceMono',
        fontSize: size,
        color: color,
        fontWeight: weight,
        letterSpacing: 0.2);

TextStyle sans(double size,
        {Color color = OnefopColors.white,
        FontWeight weight = FontWeight.normal}) =>
    GoogleFonts.dmSans(fontSize: size, color: color, fontWeight: weight);

// ── PhaseChips ────────────────────────────────────────────────────────────────
class PhaseChips extends StatelessWidget {
  final int currentStep;
  final void Function(int phase) onPhaseTap;

  const PhaseChips(
      {super.key,
      required this.currentStep,
      required this.onPhaseTap,
      required int totalSteps});

  static const _phases = [
    (name: 'Identité', maxStep: 1),
    (name: 'Emploi', maxStep: 4),
    (name: 'Mouvements', maxStep: 6),
    (name: 'Compétences', maxStep: 7),
    (name: 'Envoi', maxStep: 8),
  ];

  int get _currentPhase {
    for (int i = 0; i < _phases.length; i++) {
      if (currentStep <= _phases[i].maxStep) return i;
    }
    return _phases.length - 1;
  }

  bool _isDone(int i) => currentStep > _phases[i].maxStep;

  int _minStep(int i) => i == 0 ? 0 : _phases[i - 1].maxStep + 1;
  int _stepsIn(int i) => _phases[i].maxStep - _minStep(i) + 1;

  @override
  Widget build(BuildContext context) {
    final cp = _currentPhase;
    return Container(
      color: OnefopColors.surface,
      padding: const EdgeInsets.fromLTRB(12, 6, 12, 10),
      child: SingleChildScrollView(
        scrollDirection: Axis.horizontal,
        child: Row(
          children: List.generate(_phases.length, (i) {
            final done = _isDone(i);
            final active = i == cp;
            final stepsInPhase = _stepsIn(i);
            final stepWithin = currentStep - _minStep(i) + 1;
            final label = (active && stepsInPhase > 1)
                ? '${_phases[i].name} $stepWithin/$stepsInPhase'
                : _phases[i].name;
            return GestureDetector(
              onTap: () => onPhaseTap(i),
              child: AnimatedContainer(
                duration: const Duration(milliseconds: 200),
                margin: const EdgeInsets.only(right: 8),
                padding:
                    const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                decoration: BoxDecoration(
                  color: active
                      ? OnefopColors.teal.withAlpha(25)
                      : done
                          ? OnefopColors.teal.withAlpha(10)
                          : Colors.transparent,
                  borderRadius: BorderRadius.circular(20),
                  border: Border.all(
                    color: active
                        ? OnefopColors.teal
                        : done
                            ? OnefopColors.teal.withAlpha(80)
                            : OnefopColors.border,
                    width: active ? 1.5 : 1,
                  ),
                ),
                child: Row(mainAxisSize: MainAxisSize.min, children: [
                  if (done) ...[
                    Icon(Icons.check_rounded,
                        size: 11, color: OnefopColors.teal.withAlpha(200)),
                    const SizedBox(width: 4),
                  ],
                  Text(
                    label,
                    style: mono(9,
                        color: active
                            ? OnefopColors.teal
                            : done
                                ? OnefopColors.teal.withAlpha(160)
                                : OnefopColors.white40,
                        weight: active ? FontWeight.bold : FontWeight.normal),
                  ),
                ]),
              ),
            );
          }),
        ),
      ),
    );
  }
}

// ── SuccessOverlay ────────────────────────────────────────────────────────────
class SuccessOverlay extends StatefulWidget {
  final String referenceNumber;
  final VoidCallback onPreviewPdf;
  final VoidCallback onDashboard;

  const SuccessOverlay({
    super.key,
    required this.referenceNumber,
    required this.onPreviewPdf,
    required this.onDashboard,
  });

  @override
  State<SuccessOverlay> createState() => _SuccessOverlayState();
}

class _SuccessOverlayState extends State<SuccessOverlay>
    with SingleTickerProviderStateMixin {
  late AnimationController _ctrl;
  late Animation<double> _scale;
  late Animation<double> _fade;

  @override
  void initState() {
    super.initState();
    _ctrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 550));
    _scale = CurvedAnimation(parent: _ctrl, curve: Curves.easeOutBack);
    _fade = CurvedAnimation(parent: _ctrl, curve: Curves.easeOut);
    _ctrl.forward();
  }

  @override
  void dispose() {
    _ctrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return FadeTransition(
      opacity: _fade,
      child: Container(
        color: OnefopColors.bg.withAlpha(230),
        child: Center(
          child: ScaleTransition(
            scale: _scale,
            child: Container(
              margin: const EdgeInsets.symmetric(horizontal: 28),
              padding: const EdgeInsets.symmetric(horizontal: 28, vertical: 36),
              decoration: BoxDecoration(
                color: OnefopColors.surface,
                borderRadius: BorderRadius.circular(24),
                border: Border.all(color: OnefopColors.teal.withAlpha(60)),
                boxShadow: [
                  BoxShadow(
                      color: OnefopColors.teal.withAlpha(15),
                      blurRadius: 40,
                      spreadRadius: 4),
                ],
              ),
              child: Column(mainAxisSize: MainAxisSize.min, children: [
                Container(
                  width: 80,
                  height: 80,
                  decoration: BoxDecoration(
                    color: OnefopColors.teal.withAlpha(25),
                    shape: BoxShape.circle,
                    border: Border.all(color: OnefopColors.teal, width: 2),
                  ),
                  child: const Icon(Icons.check_rounded,
                      color: OnefopColors.teal, size: 40),
                ),
                const SizedBox(height: 20),
                Text(
                  'Questionnaire soumis\navec succès !',
                  textAlign: TextAlign.center,
                  style: sans(20, weight: FontWeight.bold),
                ),
                const SizedBox(height: 10),
                Container(
                  padding:
                      const EdgeInsets.symmetric(horizontal: 14, vertical: 8),
                  decoration: BoxDecoration(
                    color: OnefopColors.card,
                    borderRadius: BorderRadius.circular(10),
                    border: Border.all(color: OnefopColors.teal.withAlpha(40)),
                  ),
                  child: Text(widget.referenceNumber,
                      style: mono(12,
                          color: OnefopColors.teal, weight: FontWeight.bold)),
                ),
                const SizedBox(height: 28),
                _OverlayBtn(
                  label: 'Aperçu PDF (3 exemplaires)',
                  icon: Icons.picture_as_pdf_outlined,
                  onTap: widget.onPreviewPdf,
                  outlined: true,
                ),
                const SizedBox(height: 10),
                _OverlayBtn(
                  label: 'Retour au tableau de bord',
                  icon: Icons.dashboard_outlined,
                  onTap: widget.onDashboard,
                ),
              ]),
            ),
          ),
        ),
      ),
    );
  }
}

class _OverlayBtn extends StatelessWidget {
  final String label;
  final IconData icon;
  final VoidCallback onTap;
  final bool outlined;
  const _OverlayBtn(
      {required this.label,
      required this.icon,
      required this.onTap,
      this.outlined = false});

  @override
  Widget build(BuildContext context) {
    return GestureDetector(
      onTap: onTap,
      child: Container(
        width: double.infinity,
        padding: const EdgeInsets.symmetric(vertical: 14),
        decoration: BoxDecoration(
          color: outlined ? Colors.transparent : OnefopColors.teal,
          borderRadius: BorderRadius.circular(12),
          border: Border.all(
              color: outlined ? OnefopColors.white40 : Colors.transparent),
        ),
        child: Row(mainAxisAlignment: MainAxisAlignment.center, children: [
          Icon(icon,
              size: 16,
              color: outlined ? OnefopColors.white70 : OnefopColors.bg),
          const SizedBox(width: 8),
          Text(label,
              style: mono(11,
                  color: outlined ? OnefopColors.white70 : OnefopColors.bg,
                  weight: FontWeight.bold)),
        ]),
      ),
    );
  }
}

// ── FormCard ──────────────────────────────────────────────────────────────────
class FormCard extends StatelessWidget {
  final String? title;
  final Widget child;
  const FormCard({super.key, this.title, required this.child});

  @override
  Widget build(BuildContext context) {
    return Container(
      margin: const EdgeInsets.only(bottom: 14),
      decoration: BoxDecoration(
        color: OnefopColors.card,
        borderRadius: BorderRadius.circular(14),
        border: Border.all(color: OnefopColors.border),
      ),
      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        if (title != null)
          Padding(
            padding: const EdgeInsets.fromLTRB(14, 10, 14, 0),
            child: Text(title!,
                style:
                    mono(9, color: OnefopColors.teal, weight: FontWeight.bold)),
          ),
        Padding(
          padding: title != null
              ? const EdgeInsets.fromLTRB(14, 8, 14, 14)
              : const EdgeInsets.all(14),
          child: child,
        ),
      ]),
    );
  }
}

// ── field() ───────────────────────────────────────────────────────────────────
Widget field(String label, String? hint, TextEditingController ctrl,
    {TextInputType type = TextInputType.text,
    int? maxLength,
    bool required = false}) {
  return Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
    Text(label, style: mono(10, color: OnefopColors.white70)),
    const SizedBox(height: 4),
    TextFormField(
      controller: ctrl,
      keyboardType: type,
      maxLength: maxLength,
      style: sans(13, color: OnefopColors.white),
      validator: required
          ? (v) => (v == null || v.trim().isEmpty) ? 'Champ requis' : null
          : null,
      decoration: InputDecoration(
        hintText: hint,
        hintStyle: sans(13, color: OnefopColors.white20),
        filled: true,
        fillColor: OnefopColors.surface,
        counterText: '',
        contentPadding:
            const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
        border: OutlineInputBorder(
            borderRadius: BorderRadius.circular(8),
            borderSide: const BorderSide(color: OnefopColors.border)),
        enabledBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(8),
            borderSide: const BorderSide(color: OnefopColors.border)),
        focusedBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(8),
            borderSide: const BorderSide(color: OnefopColors.teal, width: 1.5)),
        errorBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(8),
            borderSide: const BorderSide(color: OnefopColors.rose, width: 1)),
        focusedErrorBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(8),
            borderSide: const BorderSide(color: OnefopColors.rose, width: 1.5)),
      ),
    ),
    const SizedBox(height: 12),
  ]);
}

// ── radioGroup() ──────────────────────────────────────────────────────────────
Widget radioGroup<T>(String label, List<({T value, String text})> options,
    T selected, ValueChanged<T?> onChanged) {
  return Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
    if (label.isNotEmpty) ...[
      Text(label, style: mono(9, color: OnefopColors.white40)),
      const SizedBox(height: 6),
    ],
    Wrap(
      spacing: 8,
      runSpacing: 6,
      children: options.map((o) {
        final isSelected = o.value == selected;
        return Material(
          color: Colors.transparent,
          borderRadius: BorderRadius.circular(8),
          child: InkWell(
            onTap: () => onChanged(o.value),
            borderRadius: BorderRadius.circular(8),
            splashColor: OnefopColors.teal.withAlpha(20),
            child: AnimatedContainer(
              duration: const Duration(milliseconds: 150),
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
              decoration: BoxDecoration(
                color: isSelected
                    ? OnefopColors.teal.withAlpha(25)
                    : Colors.transparent,
                borderRadius: BorderRadius.circular(8),
                border: Border.all(
                    color: isSelected ? OnefopColors.teal : OnefopColors.border,
                    width: isSelected ? 1.5 : 1),
              ),
              child: Text(o.text,
                  style: mono(10,
                      color:
                          isSelected ? OnefopColors.teal : OnefopColors.white40,
                      weight:
                          isSelected ? FontWeight.bold : FontWeight.normal)),
            ),
          ),
        );
      }).toList(),
    ),
    const SizedBox(height: 12),
  ]);
}

// ── PageScaffold ──────────────────────────────────────────────────────────────
class PageScaffold extends StatelessWidget {
  final String sectionCode, sectionTitle, sectionTitleEn;
  final Widget child;
  const PageScaffold(
      {super.key,
      required this.sectionCode,
      required this.sectionTitle,
      required this.sectionTitleEn,
      required this.child});

  @override
  Widget build(BuildContext context) {
    return SingleChildScrollView(
      padding: const EdgeInsets.fromLTRB(16, 16, 16, 8),
      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        Row(children: [
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 3),
            decoration: BoxDecoration(
              color: OnefopColors.teal.withAlpha(20),
              borderRadius: BorderRadius.circular(6),
              border: Border.all(color: OnefopColors.teal.withAlpha(60)),
            ),
            child: Text(sectionCode,
                style:
                    mono(8, color: OnefopColors.teal, weight: FontWeight.bold)),
          ),
        ]),
        const SizedBox(height: 6),
        Text(sectionTitle, style: sans(18, weight: FontWeight.w700)),
        if (sectionTitleEn.isNotEmpty) ...[
          const SizedBox(height: 2),
          Text(sectionTitleEn, style: mono(9, color: OnefopColors.white40)),
        ],
        const SizedBox(height: 16),
        child,
      ]),
    );
  }
}

