// ── TopBar ────────────────────────────────────────────────────────────────────
class TopBar extends StatelessWidget {
  final String entityLabel;
  final String stepTitle;
  final double progressValue;
  final VoidCallback? onBack;
  final int? currentStep;
  final int? totalSteps;

  const TopBar({
    super.key,
    required this.entityLabel,
    required this.stepTitle,
    required this.progressValue,
    this.onBack,
    this.currentStep,
    this.totalSteps,
  });

  @override
  Widget build(BuildContext context) {
    return Container(
      color: OnefopColors.surface,
      padding: EdgeInsets.only(
          top: MediaQuery.of(context).padding.top + 8,
          bottom: 12,
          left: 16,
          right: 16),
      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        Row(children: [
          if (onBack != null) ...[
            GestureDetector(
              onTap: onBack,
              child: Container(
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                    color: OnefopColors.border,
                    borderRadius: BorderRadius.circular(10)),
                child: const Icon(Icons.arrow_back_rounded,
                    color: OnefopColors.white70, size: 20),
              ),
            ),
            const SizedBox(width: 12),
          ],
          Expanded(
            child:
                Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
              Row(children: [
                Container(
                  padding:
                      const EdgeInsets.symmetric(horizontal: 8, vertical: 3),
                  decoration: BoxDecoration(
                    color: OnefopColors.teal.withAlpha(25),
                    borderRadius: BorderRadius.circular(6),
                    border: Border.all(color: OnefopColors.teal.withAlpha(80)),
                  ),
                  child: Text(entityLabel,
                      style: mono(9,
                          color: OnefopColors.teal, weight: FontWeight.bold)),
                ),
                const SizedBox(width: 8),
                Text('ONEFOP 2025',
                    style: mono(9, color: OnefopColors.white40)),
                if (currentStep != null && totalSteps != null) ...[
                  const SizedBox(width: 8),
                  Text('${currentStep! + 1}/$totalSteps',
                      style: mono(9, color: OnefopColors.white40)),
                ],
              ]),
              const SizedBox(height: 3),
              Text(stepTitle,
                  style: sans(14, weight: FontWeight.w700),
                  overflow: TextOverflow.ellipsis),
            ]),
          ),
        ]),
        const SizedBox(height: 10),
        TweenAnimationBuilder<double>(
          tween: Tween(end: progressValue),
          duration: const Duration(milliseconds: 400),
          curve: Curves.easeOutCubic,
          builder: (_, v, __) => ClipRRect(
            borderRadius: BorderRadius.circular(3),
            child: LinearProgressIndicator(
              value: v,
              minHeight: 4,
              backgroundColor: OnefopColors.white20,
              valueColor: const AlwaysStoppedAnimation(OnefopColors.teal),
            ),
          ),
        ),
      ]),
    );
  }
}

// ── BottomNav ─────────────────────────────────────────────────────────────────
class BottomNav extends StatelessWidget {
  final int step, stepCount;
  final bool submitting;
  final VoidCallback? onBack, onNext, onSubmit, onCancel;

  const BottomNav({
    super.key,
    required this.step,
    required this.stepCount,
    required this.submitting,
    this.onBack,
    this.onNext,
    this.onSubmit,
    this.onCancel,
  });

  @override
  Widget build(BuildContext context) {
    return Container(
      color: OnefopColors.surface,
      padding: EdgeInsets.only(
          left: 16,
          right: 16,
          top: 12,
          bottom: MediaQuery.of(context).padding.bottom + 12),
      child: Row(children: [
        if (onBack != null) ...[
          Expanded(
            flex: 2,
            child: _NavButton(
              label: 'Précédent',
              icon: Icons.arrow_back_ios_rounded,
              onTap: onBack,
              color: OnefopColors.white40,
              outlined: true,
            ),
          ),
          const SizedBox(width: 12),
        ] else if (step == 0 && onCancel != null) ...[
          Expanded(
            flex: 2,
            child: _NavButton(
              label: 'Fermer',
              icon: Icons.close_rounded,
              onTap: onCancel,
              color: OnefopColors.white40,
              outlined: true,
            ),
          ),
          const SizedBox(width: 12),
        ],
        Expanded(
          flex: 3,
          child: onSubmit != null
              ? _NavButton(
                  label: submitting ? 'Envoi en cours...' : 'Soumettre',
                  icon: submitting ? null : Icons.check_circle_rounded,
                  onTap: submitting ? null : onSubmit,
                  color: OnefopColors.teal,
                  loading: submitting,
                )
              : _NavButton(
                  label: 'Suivant',
                  icon: Icons.arrow_forward_ios_rounded,
                  iconTrailing: true,
                  onTap: onNext,
                  color: OnefopColors.teal,
                ),
        ),
      ]),
    );
  }
}

class _NavButton extends StatelessWidget {
  final String label;
  final IconData? icon;
  final bool iconTrailing, outlined, loading;
  final VoidCallback? onTap;
  final Color color;
  const _NavButton(
      {required this.label,
      this.icon,
      this.iconTrailing = false,
      this.outlined = false,
      this.loading = false,
      this.onTap,
      required this.color});

  @override
  Widget build(BuildContext context) {
    return GestureDetector(
      onTap: onTap,
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 180),
        height: 46,
        decoration: BoxDecoration(
          color: outlined ? Colors.transparent : color,
          borderRadius: BorderRadius.circular(10),
          border: Border.all(
              color: outlined ? color.withAlpha(80) : Colors.transparent),
        ),
        child: Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            if (loading) ...[
              SizedBox(
                  width: 16,
                  height: 16,
                  child: CircularProgressIndicator(
                      strokeWidth: 2,
                      color: outlined ? color : OnefopColors.bg)),
              const SizedBox(width: 8),
            ],
            if (!loading && icon != null && !iconTrailing) ...[
              Icon(icon, size: 14, color: outlined ? color : OnefopColors.bg),
              const SizedBox(width: 6),
            ],
            Text(label,
                style: mono(11,
                    color: outlined ? color : OnefopColors.bg,
                    weight: FontWeight.bold)),
            if (!loading && icon != null && iconTrailing) ...[
              const SizedBox(width: 6),
              Icon(icon, size: 14, color: outlined ? color : OnefopColors.bg),
            ],
          ],
        ),
      ),
    );
  }
}

// ── RespondentPage ────────────────────────────────────────────────────────────
class RespondentPage extends StatelessWidget {
  final TextEditingController nameCtrl,
      funcCtrl,
      phone1Ctrl,
      phone2Ctrl,
      emailCtrl;
  const RespondentPage({
    super.key,
    required this.nameCtrl,
    required this.funcCtrl,
    required this.phone1Ctrl,
    required this.phone2Ctrl,
    required this.emailCtrl,
  });

  @override
  Widget build(BuildContext context) {
    return PageScaffold(
      sectionCode: 'SECTION 0',
      sectionTitle: 'Identification du Répondant',
      sectionTitleEn: 'Identification of Respondent',
      child: Column(children: [
        FormCard(
          title: 'S0Q01 — Noms et prénoms / Full name',
          child: field('Noms, prénoms du répondant', 'Jean Dupont', nameCtrl),
        ),
        FormCard(
          title: 'S0Q02 — Fonction / Function',
          child: field('Fonction du répondant', 'Directeur RH', funcCtrl),
        ),
        FormCard(
          title: 'S0Q03 — Contacts',
          child: Column(children: [
            field('Téléphone 1', 'Ex: 677123456', phone1Ctrl,
                type: TextInputType.phone),
            field('Téléphone 2', 'Ex: 699123456', phone2Ctrl,
                type: TextInputType.phone),
            field('E-mail', 'exemple@domaine.cm', emailCtrl,
                type: TextInputType.emailAddress),
          ]),
        ),
      ]),
    );
  }
}
