{
  "name": "dsmo-backend",
  "version": "1.0.0",
  "description": "DSMO digital declaration backend",
  "engines": {
    "node": ">=20.x"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "build": "nest build && node -e \"const{cpSync}=require('fs');cpSync('src/pdf/templates','dist/pdf/templates',{recursive:true})\"",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate && npx puppeteer browsers install chrome",
    "test": "jest"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.103.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pdfkit-table": "^0.1.99",
    "playwright": "^1.61.0",
    "prisma": "^5.22.0",
    "puppeteer": "22.15.0",
    "reflect-metadata": "^0.1.14",
    "resend": "^6.14.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.25",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.5",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
