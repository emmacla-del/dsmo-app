generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS FIRST ============
enum UserRole {
  COMPANY
  DIVISIONAL
  REGIONAL
  CENTRAL
}

enum DeclarationStatus {
  DRAFT
  SUBMITTED
  DIVISION_APPROVED
  REGION_APPROVED
  FINAL_APPROVED
  REJECTED
}

enum NotificationStatus {
  SENT
  FAILED
  BOUNCED
  OPENED
}

enum MovementType {
  RECRUITMENT
  PROMOTION
  DISMISSAL
  RETIREMENT
  DEATH
}

enum ValidationStepType {
  GENDER_SUM
  CATEGORY_SUM
  MOVEMENT_CONSISTENCY
  WORKFORCE_GROWTH
  EMPLOYEE_VALIDATION
  OVERALL_CONSISTENCY
}

enum QuestionType {
  TRAINING_CENTER
  RECRUITMENT_PLANS
  CAMEROUNISATION
  TEMP_AGENCIES
  QUALITATIVE
  QUANTITATIVE
}

enum QuestionSection {
  GENERAL
  EMPLOYMENT
  TRAINING
  DIVERSITY
  FUTURE_PLANS
}

// ============ NEW ENUMS FOR MINEFOP HIERARCHY ============
enum ServiceCategory {
  DECONCENTRE   // Regional/Departmental delegations
  CENTRALE      // Central administration
  RATTACHE      // Attached organizations
}

enum PositionType {
  HEAD              // Chef de Direction / Chef de Service / Chef de Bureau
  DEPUTY_HEAD       // Chef de Service Adjoint / Chef de Bureau Adjoint
  DIVISION_HEAD     // Chef de Division
  SUB_DIRECTION_HEAD // Chef de Sous-Direction
  OFFICER           // Chargé d'Études / Chargé de Mission
  ASSISTANT         // Assistant / Attaché
  TECHNICIAN        // Technicien
  ADMIN             // Administrateur
}

// ============ LOCATION AND SECTOR MODELS ============
model Region {
  id          String       @id @default(uuid())
  name        String       @unique
  nameEn      String?
  code        String?      @unique
  departments Department[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("regions")
}

model Department {
  id           String         @id @default(uuid())
  name         String
  nameEn       String?
  code         String?        @unique
  regionId     String
  region       Region         @relation(fields: [regionId], references: [id], onDelete: Cascade)
  subdivisions Subdivision[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([regionId, name])
  @@map("departments")
}

model Subdivision {
  id           String       @id @default(uuid())
  name         String
  nameEn       String?
  code         String?      @unique
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([departmentId, name])
  @@map("subdivisions")
}

model Sector {
  id        String   @id @default(uuid())
  name      String   @unique
  nameEn    String?
  code      String?  @unique
  category  String?  // Primary, Secondary, Tertiary, Public
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sectors")
}

// ============ NEW: MINEFOP SERVICE HIERARCHY ============
model MinefopService {
  id                 String            @id @default(uuid())
  // ✅ FIX 1: Removed duplicate @unique here — @@unique([code]) below already enforces uniqueness.
  //           Having both caused constraint name collision: `minefop_services_code_key`
  code               String
  name               String
  nameEn             String?
  acronym            String?
  category           ServiceCategory   @default(CENTRALE)
  level              Int               // 1=Direction, 2=Sous-Direction, 3=Service, 4=Bureau
  parentCode         String?
  parent             MinefopService?   @relation("ServiceHierarchy", fields: [parentCode], references: [code])
  children           MinefopService[]  @relation("ServiceHierarchy")
  roleMapping        UserRole          // CENTRAL, REGIONAL, DIVISIONAL, COMPANY
  requiresRegion     Boolean           @default(false)
  requiresDepartment Boolean           @default(false)
  orderIndex         Int
  isActive           Boolean           @default(true)
  positions          ServicePosition[] // Positions available in this service
  // ✅ FIX 2: Added back-relation for User.service field
  users              User[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // ✅ FIX 1 (continued): Keep only @@unique([code]) with explicit map name to avoid collision
  @@unique([code], map: "minefop_services_code_unique")
  @@index([parentCode])
  @@index([level])
  @@index([category])
  @@map("minefop_services")
}

// ============ NEW: SERVICE POSITIONS (ROLES WITHIN SERVICES) ============
model ServicePosition {
  id              String        @id @default(uuid())
  serviceCode     String
  service         MinefopService @relation(fields: [serviceCode], references: [code])
  positionType    PositionType
  title           String        // "Chef de Bureau", "Chargé d'Études", etc.
  titleEn         String?
  level           Int           // 1=Head, 2=Deputy, 3=Officer, 4=Assistant
  orderIndex      Int
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([serviceCode, positionType])
  @@index([serviceCode])
  @@index([level])
  @@map("service_positions")
}

// ============ MODELS THAT DON'T RELATE TO OTHERS ============
model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  firstName         String?
  lastName          String?
  role              UserRole          @default(COMPANY)
  region            String?
  department        String?
  subdivision       String?
  matricule         String?           // Government staff ID (DIVISIONAL, REGIONAL, CENTRAL only)
  poste             String?           // Job title / position (government only)
  
  // ✅ NEW: MINEFOP service and position mapping
  serviceCode       String?           // MINEFOP service (for government users)
  service           MinefopService?   @relation(fields: [serviceCode], references: [code])
  positionType      PositionType?     // Position within the service
  positionTitle     String?           // Custom title if needed
  
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  company           Company?
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@index([role])
  @@index([serviceCode])
  @@index([positionType])
  @@map("users")
}

// ============ COMPANY MODEL ============
model Company {
  id                String              @id @default(uuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id])
  name              String
  parentCompany     String?
  mainActivity      String
  secondaryActivity String?
  region            String
  department        String
  district          String
  address           String
  fax               String?
  taxNumber         String              @unique
  cnpsNumber        String?
  socialCapital     Float?
  totalEmployees    Int
  menCount          Int?
  womenCount        Int?
  lastYearTotal     Int?
  lastYearMenCount  Int?
  lastYearWomenCount Int?
  declarations      Declaration[]
  notificationRecipients NotificationRecipient[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

// ============ MODELS THAT RELATE TO DECLARATION ============
model Employee {
  id            String        @id @default(uuid())
  declarationId String
  declaration   Declaration    @relation(fields: [declarationId], references: [id])
  fullName      String
  gender        String
  age           Int
  nationality   String
  diploma       String?
  function      String
  seniority     Int
  salaryCategory String?
  salary        Int?
  createdAt     DateTime      @default(now())
}

model DeclarationMovement {
  id            String        @id @default(uuid())
  declarationId String
  declaration   Declaration   @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  movementType  MovementType
  cat1_3        Int           @default(0)
  cat4_6        Int           @default(0)
  cat7_9        Int           @default(0)
  cat10_12      Int           @default(0)
  catNonDeclared Int          @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ValidationStep {
  id            String        @id @default(uuid())
  declarationId String
  declaration   Declaration   @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  stepType      ValidationStepType
  isValid       Boolean       @default(true)
  errors        String[]      @default([])
  message       String?
  checkedBy     String?
  checkedAt     DateTime?
  createdAt     DateTime      @default(now())
}

model AuditLog {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  declarationId     String?
  declaration       Declaration?      @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  action            String
  resourceType      String
  resourceId        String
  details           String?
  previousValue     String?
  newValue          String?
  timestamp         DateTime          @default(now())
  createdAt         DateTime          @default(now())

  @@index([userId])
  @@index([declarationId])
  @@index([timestamp])
}

model Notification {
  id                String                  @id @default(uuid())
  sentBy            String
  senderUser        User                    @relation(fields: [sentBy], references: [id])
  regionFilter      String?
  departmentFilter  String?
  submissionStatus  DeclarationStatus?
  subject           String
  message           String
  recipientCount    Int                     @default(0)
  sentAt            DateTime                @default(now())
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  recipients        NotificationRecipient[]

  @@index([sentBy])
  @@index([sentAt])
}

model NotificationRecipient {
  id               String         @id @default(uuid())
  notificationId   String
  notification     Notification   @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email            String
  status           NotificationStatus @default(SENT)
  sentAt           DateTime       @default(now())
  openedAt         DateTime?
  clickedAt        DateTime?
  createdAt        DateTime       @default(now())
}

model AnalyticsSnapshot {
  id                String        @id @default(uuid())
  year              Int
  region            String?
  department        String?
  totalEmployment   Int
  maleEmployment    Int
  femaleEmployment  Int
  totalRecruitment  Int
  totalDismissals   Int
  avgSalaryCategory Float?
  companiesSubmitted Int
  companiesApproved Int
  companiesPending  Int
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ============ DECLARATION MODEL (AFTER ALL REFERENCED MODELS) ============
model Declaration {
  id                  String              @id @default(uuid())
  year                Int
  fillingDate         DateTime?
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id])
  region              String
  division            String
  status              DeclarationStatus   @default(DRAFT)
  submittedAt         DateTime?
  validatedBy         String?
  validatedAt         DateTime?
  rejectionReason     String?
  pdfUrl              String?
  receiptUrl          String?
  qrCode              String?
  employees           Employee[]
  movements           DeclarationMovement[]
  qualitativeQuestions QualitativeQuestion[]
  validationSteps     ValidationStep[]
  auditLogs           AuditLog[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

// ============ QUALITATIVE QUESTION MODEL (AFTER DECLARATION) ============
model QualitativeQuestion {
  id            String        @id @default(uuid())
  declarationId String
  declaration   Declaration   @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  questionType  QuestionType  @default(QUALITATIVE)
  section       QuestionSection @default(GENERAL)
  questionText  String
  answerText    String?
  answerOptions Json?

  hasTrainingCenter     Boolean?
  trainingCenterDetails String?
  recruitmentPlansNext  Boolean?
  recruitmentPlanCount  Int?
  camerounisationPlan   Boolean?
  usesTempAgencies      Boolean?
  temporaryWorkerCount  Int?
  tempAgencyDetails     String?

  version       Int           @default(1)
  orderIndex    Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([declarationId])
  @@index([questionType])
  @@index([section])
  @@unique([declarationId, questionType, version])
}
