generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MinefopService {
  code               String            @id
  name               String
  nameEn             String?
  acronym            String?
  category           ServiceCategory
  level              Int
  parentCode         String?
  roleMapping        UserRole
  requiresRegion     Boolean           @default(false)
  requiresDepartment Boolean           @default(false)
  orderIndex         Int
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  parent             MinefopService?   @relation("ServiceHierarchy", fields: [parentCode], references: [code])
  children           MinefopService[]  @relation("ServiceHierarchy")
  positions          ServicePosition[]
  users              User[]

  @@map("minefop_services")
}

model ServicePosition {
  id           String         @id @default(uuid())
  serviceCode  String
  positionType String
  title        String
  titleEn      String?
  level        Int
  orderIndex   Int
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  service      MinefopService @relation(fields: [serviceCode], references: [code])

  @@unique([serviceCode, positionType])
  @@map("service_positions")
}

model Region {
  id                String             @id @default(uuid())
  name              String             @unique
  code              String?            @unique
  nameEn            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companies         Company[]
  departments       Department[]
  onefopSubmissions OnefopSubmission[]

  @@map("regions")
}

model Department {
  id                String             @id @default(uuid())
  name              String
  code              String?            @unique
  nameEn            String?
  regionId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companies         Company[]
  region            Region             @relation(fields: [regionId], references: [id])
  onefopSubmissions OnefopSubmission[]
  subdivisions      Subdivision[]

  @@unique([regionId, name])
  @@map("departments")
}

model Subdivision {
  id                String             @id @default(uuid())
  name              String
  code              String?            @unique
  nameEn            String?
  departmentId      String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companies         Company[]
  onefopSubmissions OnefopSubmission[]
  department        Department         @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, name])
  @@map("subdivisions")
}

model Sector {
  id                 String                    @id @default(uuid())
  name               String                    @unique
  code               String?                   @unique
  category           String?
  nameEn             String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  companies          Company[]
  onefopEnterprises  OnefopEnterpriseDetail[]
  onefopCooperatives OnefopCooperativeDetail[]
  onefopCtds         OnefopCtdDetail[]
  onefopOngs         OnefopOngDetail[]

  @@map("sectors")
}

model User {
  id                         String             @id @default(uuid())
  email                      String             @unique
  passwordHash               String
  firstName                  String?
  lastName                   String?
  role                       UserRole           @default(COMPANY)
  region                     String?
  department                 String?
  subdivision                String?
  matricule                  String?
  poste                      String?
  serviceCode                String?
  positionType               String?
  positionTitle              String?
  isActive                   Boolean            @default(true)
  rejectionReason            String?
  rejectedAt                 DateTime?
  passwordResetTokenHash     String?
  passwordResetExpires       DateTime?
  mustChangePassword         Boolean            @default(false)
  emailVerified              Boolean            @default(true)
  emailVerificationTokenHash String?
  emailVerificationExpires   DateTime?
  emailNotificationsEnabled  Boolean            @default(true)
  pushNotificationsEnabled   Boolean            @default(true)
  weeklyDigestEnabled        Boolean            @default(false)
  smsNotificationsEnabled    Boolean            @default(false)
  twoFactorEnabled           Boolean            @default(false)
  twoFactorCodeHash          String?
  twoFactorCodeExpires       DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  status                     UserStatus         @default(PENDING_APPROVAL)
  auditLogs                  AuditLog[]
  batchJobs                  BatchJob[]
  company                    Company?
  createdCampaigns           DataCampaign[]     @relation("CampaignCreatedBy")
  distributionLists          DistributionList[]
  distributionLogs           DistributionLog[]
  notifications              Notification[]
  onefopSubmissions          OnefopSubmission[]
  approvedReports            Report[]           @relation("ReportApprovedBy")
  generatedReports           Report[]
  scheduledReports           ScheduledReport[]
  submissionDrafts           SubmissionDraft[]
  closedRounds               SubmissionRound[]  @relation("RoundClosedBy")
  openedRounds               SubmissionRound[]  @relation("RoundOpenedBy")
  minefopService             MinefopService?    @relation(fields: [serviceCode], references: [code])

  @@index([role])
  @@index([serviceCode])
  @@map("users")
}

model Company {
  id                         String                  @id @default(uuid())
  userId                     String                  @unique
  name                       String
  parentCompany              String?
  mainActivity               String
  secondaryActivity          String?
  region                     String
  department                 String
  subdivision                String
  address                    String
  taxNumber                  String                  @unique
  cnpsNumber                 String?
  socialCapital              Float?
  totalEmployees             Int
  menCount                   Int?
  womenCount                 Int?
  lastYearTotal              Int?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  fax                        String?
  lastYearMenCount           Int?
  lastYearWomenCount         Int?
  entityType                 OnefopEntityType?
  sectorId                   String?
  regionId                   String?
  departmentId               String?
  subdivisionId              String?
  area                       String?
  cooperativeType            String?
  ctdType                    String?
  legalStatus                String?
  mainMission                String?
  phone                      String?
  phone2                     String?
  poBox                      String?
  registrationNumber         String?
  respondentFunction         String?
  respondentPhone            String?
  respondentPhone2           String?
  trainingDomains            String?
  yearOfCreation             String?
  branch                     String?
  respondentFirstName        String?
  respondentLastName         String?
  enterpriseSize             String?
  establishmentId            String?
  establishmentIdGeneratedAt DateTime?               @db.Timestamp(6)
  attestationUrl             String?
  attestationGeneratedAt     DateTime?               @db.Timestamp(6)
  campaignSubmissions        CampaignSubmission[]
  departmentRef              Department?             @relation(fields: [departmentId], references: [id])
  regionRef                  Region?                 @relation(fields: [regionId], references: [id])
  sector                     Sector?                 @relation(fields: [sectorId], references: [id])
  subdivisionRef             Subdivision?            @relation(fields: [subdivisionId], references: [id])
  user                       User                    @relation(fields: [userId], references: [id])
  declarations               Declaration[]
  notificationRecipients     NotificationRecipient[]
  onefopSubmissions          OnefopSubmission[]

  @@index([establishmentId], map: "idx_companies_establishmentId")
  @@map("companies")
}

model Declaration {
  id                   String                @id @default(uuid())
  year                 Int
  companyId            String
  region               String
  division             String
  status               DeclarationStatus     @default(DRAFT)
  submittedAt          DateTime?
  validatedBy          String?
  validatedAt          DateTime?
  rejectionReason      String?
  pdfUrl               String?
  receiptUrl           String?
  qrCode               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  fillingDate          DateTime?
  auditLogs            AuditLog[]
  movements            DeclarationMovement[]
  company              Company               @relation(fields: [companyId], references: [id])
  employees            Employee[]
  qualitativeQuestions QualitativeQuestion[]
  validationSteps      ValidationStep[]

  @@map("declarations")
}

model Employee {
  id             String      @id @default(uuid())
  declarationId  String
  fullName       String
  gender         String
  age            Int
  nationality    String
  diploma        String?
  function       String
  seniority      Int
  salaryCategory String?
  createdAt      DateTime    @default(now())
  salary         Int?
  declaration    Declaration @relation(fields: [declarationId], references: [id])

  @@map("employees")
}

model DeclarationMovement {
  id             String       @id @default(uuid())
  declarationId  String
  movementType   MovementType
  cat1_3         Int          @default(0)
  cat4_6         Int          @default(0)
  cat7_9         Int          @default(0)
  cat10_12       Int          @default(0)
  catNonDeclared Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  declaration    Declaration  @relation(fields: [declarationId], references: [id])

  @@map("declaration_movements")
}

model ValidationStep {
  id            String             @id @default(uuid())
  declarationId String
  stepType      ValidationStepType
  isValid       Boolean            @default(true)
  errors        String[]           @default([])
  message       String?
  checkedBy     String?
  checkedAt     DateTime?
  createdAt     DateTime           @default(now())
  declaration   Declaration        @relation(fields: [declarationId], references: [id])

  @@map("validation_steps")
}

model QualitativeQuestion {
  id                    String      @id @default(uuid())
  declarationId         String
  questionType          String
  section               String
  questionText          String
  answerText            String?
  answerOptions         Json?
  hasTrainingCenter     Boolean?
  trainingCenterDetails String?
  recruitmentPlansNext  Boolean?
  recruitmentPlanCount  Int?
  camerounisationPlan   Boolean?
  usesTempAgencies      Boolean?
  temporaryWorkerCount  Int?
  version               Int         @default(1)
  orderIndex            Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  tempAgencyDetails     String?
  declaration           Declaration @relation(fields: [declarationId], references: [id])

  @@map("qualitative_questions")
}

model Notification {
  id               String                  @id @default(uuid())
  sentBy           String
  regionFilter     String?
  departmentFilter String?
  submissionStatus DeclarationStatus?
  subject          String
  message          String
  recipientCount   Int                     @default(0)
  sentAt           DateTime                @default(now())
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  recipients       NotificationRecipient[]
  senderUser       User                    @relation(fields: [sentBy], references: [id])

  @@map("notifications")
}

model NotificationRecipient {
  id             String             @id @default(uuid())
  notificationId String
  companyId      String
  email          String
  status         NotificationStatus @default(SENT)
  sentAt         DateTime           @default(now())
  openedAt       DateTime?
  clickedAt      DateTime?
  createdAt      DateTime           @default(now())
  company        Company            @relation(fields: [companyId], references: [id])
  notification   Notification       @relation(fields: [notificationId], references: [id])

  @@map("notification_recipients")
}

model AuditLog {
  id            String       @id @default(uuid())
  userId        String
  declarationId String?
  action        String
  resourceType  String
  resourceId    String
  details       Json?
  previousValue String?
  newValue      String?
  timestamp     DateTime     @default(now())
  createdAt     DateTime     @default(now())
  reportId      String?
  ipAddress     String?
  userAgent     String?
  declaration   Declaration? @relation(fields: [declarationId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([declarationId])
  @@index([timestamp])
  @@index([action])
  @@index([reportId])
  @@map("audit_logs")
}

model DataCampaign {
  id                String               @id @default(uuid())
  description       String?
  startDate         DateTime?
  endDate           DateTime?
  createdBy         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  autoReminders     Boolean              @default(false)
  closedAt          DateTime?
  code              String               @unique
  deadline          DateTime?
  extendedDeadline  DateTime?
  name              String
  reminderDays      Int[]                @default([])
  targetDepartments String[]             @default([])
  targetEntityTypes String[]             @default([])
  targetRegions     String[]             @default([])
  type              String?
  // Which form this campaign actually gates — drives the SubmissionRound
  // opened/closed alongside the campaign's lifecycle (see SubmissionRound.module).
  collectionType    SubmissionModule     @default(ONEFOP)
  status            CampaignStatus       @default(DRAFT)
  reminders         CampaignReminder[]
  submissions       CampaignSubmission[]
  creator           User?                @relation("CampaignCreatedBy", fields: [createdBy], references: [id])
  round             SubmissionRound?

  @@index([status])
  @@map("data_campaigns")
}

model CampaignSubmission {
  id              String           @id @default(uuid())
  campaignId      String
  companyId       String?
  submittedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  establishmentId String?
  status          SubmissionStatus @default(PENDING)
  campaign        DataCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([campaignId, companyId])
  @@unique([campaignId, establishmentId])
  @@index([campaignId])
  @@index([companyId])
  @@index([establishmentId])
  @@map("campaign_submissions")
}

model CampaignReminder {
  id             String       @id @default(uuid())
  campaignId     String
  sentAt         DateTime     @default(now())
  message        String?
  createdAt      DateTime     @default(now())
  recipientCount Int          @default(0)
  failedCount    Int          @default(0)
  reminderType   String       @default("INITIAL")
  subject        String?
  campaign       DataCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_reminders")
}

model Report {
  id               String            @id @default(uuid())
  parameters       Json?
  fileUrl          String?
  createdBy        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expiresAt        DateTime?
  isScheduled      Boolean           @default(false)
  name             String
  schedule         String?
  type             ReportType?
  reportType       ReportType?
  format           ReportFormat
  status           String            @default("READY")
  filePath         String?
  fileHash         String?
  approvalStatus   String?           @default("PENDING")
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?
  distributionLogs DistributionLog[]
  snapshot         ReportSnapshot?
  approvedByUser   User?             @relation("ReportApprovedBy", fields: [approvedBy], references: [id], onUpdate: NoAction)
  createdByUser    User?             @relation(fields: [createdBy], references: [id])
  scheduledReports ScheduledReport[]

  @@index([reportType])
  @@index([fileHash], map: "idx_reports_fileHash")
  @@index([approvalStatus])
  @@index([approvedBy])
  @@map("reports")
}

model ReportSnapshot {
  id            String    @id @default(cuid())
  reportId      String    @unique
  computedAt    DateTime  @default(now()) @db.Timestamptz(6)
  snapshotData  Json
  sourceHash    String
  submissionIds String[]  @default([])
  approvedBy    String?
  approvedAt    DateTime?
  approvalHash  String?
  report        Report    @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "report_snapshots_reportid_fkey")

  @@map("report_snapshots")
}

model ScheduledReport {
  id            String       @id @default(uuid())
  parameters    Json?
  schedule      String
  isActive      Boolean      @default(true)
  lastRunAt     DateTime?
  createdBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  frequency     String?
  recipients    String[]     @default([])
  reportId      String?
  reportType    ReportType
  format        ReportFormat
  createdByUser User?        @relation(fields: [createdBy], references: [id])
  report        Report?      @relation(fields: [reportId], references: [id])

  @@index([reportType])
  @@map("scheduled_reports")
}

model SubmissionRound {
  id                String             @id @default(uuid())
  quarterCode       String             @unique
  labelFr           String
  labelEn           String
  periodStart       DateTime
  periodEnd         DateTime
  deadline          DateTime
  status            RoundStatus        @default(DRAFT)
  targetRegions     String[]           @default([])
  targetEntityTypes OnefopEntityType[] @default([])
  // Which form this round actually opens/closes submission for. Rounds are
  // scoped per module so an ONEFOP round and a DSMO round can be open
  // simultaneously without one closing the other.
  module            SubmissionModule   @default(ONEFOP)
  // Set when this round was opened/closed by a DataCampaign's lifecycle
  // rather than directly via the admin Submission Rounds screen.
  campaignId        String?            @unique
  openedBy          String?
  openedAt          DateTime?
  closedBy          String?
  closedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  campaign          DataCampaign?      @relation(fields: [campaignId], references: [id])
  closedByUser      User?              @relation("RoundClosedBy", fields: [closedBy], references: [id])
  openedByUser      User?              @relation("RoundOpenedBy", fields: [openedBy], references: [id])

  @@index([status])
  @@index([module, status])
  @@index([deadline])
  @@index([quarterCode])
  @@map("submission_rounds")
}

model SubmissionDraft {
  id              String           @id @default(uuid())
  establishmentId String
  quarterCode     String
  entityType      OnefopEntityType
  draftData       Json
  lastSavedAt     DateTime         @default(now())
  savedByUserId   String?
  completionScore Float?
  missingFields   String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  savedByUser     User?            @relation(fields: [savedByUserId], references: [id])

  @@unique([establishmentId, quarterCode])
  @@index([establishmentId])
  @@map("submission_drafts")
}

model OnefopSubmission {
  id                    String                        @id @default(uuid())
  submissionId          String                        @unique @default(uuid())
  formType              OnefopEntityType
  status                OnefopStatus                  @default(PENDING_REVIEW)
  rawData               Json
  flags                 Json?
  rejectionReason       String?
  reviewedBy            String?
  reviewedAt            DateTime?
  pdfUrl                String?
  surveyYear            Int
  region                String?
  department            String?
  subdivision           String?
  submittedBy           String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  companyId             String?
  regionId              String?
  departmentId          String?
  subdivisionId         String?
  establishmentId       String?
  quarterCode           String?                       @default("2025-T1")
  taxNumber             String?
  cnpsNumber            String?
  registrationNumber    String?
  metaJson              Json?
  cooperativeDetail     OnefopCooperativeDetail?
  cspGenderAge          OnefopCspGenderAge[]
  ctdDetail             OnefopCtdDetail?
  departureData         OnefopDepartureData[]
  diplomaData           OnefopDiplomaData[]
  disabilityData        OnefopDisabilityData[]
  dismissalReasons      OnefopDismissalReason[]
  dismissalUnemployment OnefopDismissalUnemployment[]
  enterpriseDetail      OnefopEnterpriseDetail?
  factRecruitments      OnefopFactRecruitment[]
  factSkillNeeds        OnefopFactSkillNeed[]
  firstTimeWorkers      OnefopFirstTimeWorker[]
  internshipData        OnefopInternshipData[]
  jobApplicationData    OnefopJobApplicationData[]
  ongDetail             OnefopOngDetail?
  registeredSeekers     OnefopRegisteredSeeker[]
  respondent            OnefopRespondent?
  skillNeeds            OnefopSkillNeed[]
  company               Company?                      @relation(fields: [companyId], references: [id])
  departmentRef         Department?                   @relation(fields: [departmentId], references: [id])
  regionRef             Region?                       @relation(fields: [regionId], references: [id])
  subdivisionRef        Subdivision?                  @relation(fields: [subdivisionId], references: [id])
  user                  User?                         @relation(fields: [submittedBy], references: [id])
  trainingNeeds         OnefopTrainingNeed[]
  vulnerableData        OnefopVulnerableData[]

  @@index([status])
  @@index([formType])
  @@index([surveyYear])
  @@index([region])
  @@index([submittedBy])
  @@index([establishmentId], map: "idx_onefop_submissions_establishmentId")
  @@index([quarterCode], map: "idx_onefop_submissions_quarterCode")
  @@index([taxNumber])
  @@index([cnpsNumber])
  @@map("onefop_submissions")
}

model OnefopRespondent {
  id                 String           @id @default(uuid())
  submissionId       String           @unique
  respondentName     String
  respondentFunction String
  phone1             String
  phone2             String?
  email              String?
  createdAt          DateTime         @default(now())
  submission         OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("onefop_respondents")
}

model OnefopEnterpriseDetail {
  id               String           @id @default(uuid())
  submissionId     String           @unique
  legalStatus      String
  companyName      String
  area             String
  region           String
  department       String
  subdivision      String
  locality         String?
  phone1           String
  phone2           String?
  poBox            String?
  sector           String
  branch           String?
  mainActivity     String
  headOffice       String?
  permanentWorkers Int
  vacancies        Int?
  enterpriseSize   String?
  createdAt        DateTime         @default(now())
  sectorId         String?
  sectorRef        Sector?          @relation(fields: [sectorId], references: [id])
  submission       OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("onefop_enterprise_details")
}

model OnefopCooperativeDetail {
  id                   String           @id @default(uuid())
  submissionId         String           @unique
  cooperativeName      String
  headOffice           String?
  yearCreated          Int?
  area                 String?
  region               String?
  department           String?
  subdivision          String?
  locality             String?
  phone1               String?
  phone2               String?
  poBox                String?
  sector               String?
  sectorId             String?
  branch               String?
  mainActivity         String?
  cooperativeType      String?
  cooperativeTypeOther String?
  permanentWorkers     Int?
  vacancies            Int?
  createdAt            DateTime         @default(now())
  sectorRef            Sector?          @relation(fields: [sectorId], references: [id])
  submission           OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("onefop_cooperative_details")
}

model OnefopCtdDetail {
  id               String           @id @default(uuid())
  submissionId     String           @unique
  ctdType          String
  councilType      String?
  yearCreated      Int?
  area             String?
  region           String?
  department       String?
  subdivision      String?
  locality         String?
  phone1           String?
  phone2           String?
  poBox            String?
  sector           String?
  sectorId         String?
  branch           String?
  permanentWorkers Int?
  vacancies        Int?
  createdAt        DateTime         @default(now())
  sectorRef        Sector?          @relation(fields: [sectorId], references: [id])
  submission       OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("onefop_ctd_details")
}

model OnefopOngDetail {
  id               String           @id @default(uuid())
  submissionId     String           @unique
  ongName          String
  headOffice       String?
  yearCreated      Int?
  area             String?
  region           String?
  department       String?
  subdivision      String?
  locality         String?
  phone1           String?
  phone2           String?
  poBox            String?
  sector           String?
  sectorId         String?
  branch           String?
  mainMission      String?
  permanentWorkers Int?
  vacancies        Int?
  createdAt        DateTime         @default(now())
  sectorRef        Sector?          @relation(fields: [sectorId], references: [id])
  submission       OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("onefop_ong_details")
}

model OnefopCspGenderAge {
  id           String           @id @default(uuid())
  submissionId String
  tableName    String
  cspCategory  CspCategory
  gender       Gender
  ageBand      AgeBand?
  value        Int              @default(0)
  createdAt    DateTime         @default(now())
  submission   OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, tableName, cspCategory, gender, ageBand])
  @@index([submissionId, tableName])
  @@map("onefop_csp_gender_age")
}

model OnefopDiplomaData {
  id           String           @id @default(uuid())
  submissionId String
  diploma      DiplomaType
  gender       Gender
  ageBand      AgeBand?
  value        Int              @default(0)
  createdAt    DateTime         @default(now())
  submission   OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, diploma, gender, ageBand])
  @@index([submissionId])
  @@map("onefop_diploma_data")
}

model OnefopDisabilityData {
  id           String           @id @default(uuid())
  submissionId String
  cspCategory  CspCategory
  status       DisabilityStatus
  gender       Gender
  value        Int              @default(0)
  createdAt    DateTime         @default(now())
  submission   OnefopSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

