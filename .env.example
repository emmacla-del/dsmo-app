# Environment Variables Configuration Template

# ==================== DATABASE ====================
DATABASE_URL="postgresql://postgres:password@localhost:5432/dsmo_db"
DATABASE_URL_SHADOW="postgresql://postgres:password@localhost:5432/dsmo_db_shadow"

# ==================== SERVER ====================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# ==================== EMAIL (SMTP) ====================
# Gmail Configuration (requires app-specific password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=dsmo-notifications@ministry.cm

# Alternative: Mailgun
# MAILGUN_DOMAIN=mail.dsmo.ministry.cm
# MAILGUN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM=dsmo@ministry.cm

# ==================== FILE STORAGE ====================
# Local file storage or cloud storage
STORAGE_TYPE=local  # 'local', 'aws-s3', 'gcs'
STORAGE_BUCKET_NAME=dsmo-declarations

# AWS S3 (if using S3)
# AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1

# ==================== SECURITY ====================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ==================== FEATURES ====================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_PDF_GENERATION=true
ENABLE_QR_CODES=true
DEADLINE_REMINDER_DAYS=14

# ==================== FLUTTER FRONTEND ====================
# Update in lib/data/api_client.dart
FLUTTER_API_BASE_URL=http://localhost:3000
FLUTTER_API_TIMEOUT_SECONDS=30
