# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Public URL of the deployed frontend (used to build links in emails, e.g. password reset)
APP_URL=https://your-frontend-domain.com

# SMTP — provider-agnostic. The backend only reads these env vars (see
# src/dsmo/notification.service.ts), so switching provider (Gmail, Brevo,
# Amazon SES, Microsoft 365, an official MINEFOP domain, etc.) never requires
# a code change — just update the values below.
#
# Currently set up for Gmail SMTP:
#   1. Enable 2-Step Verification on the Gmail account.
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#      (your normal Gmail password will NOT work as SMTP_PASS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-gmail-address@gmail.com

# Resend — used by src/email/email.service.ts to send the admin-mediated
# password reset link from noreply@dsmo-digital.com. Get this key from the
# Resend dashboard (resend.com) under API Keys, after dsmo-digital.com has
# been added and verified under Domains. Sends will fail with an
# auth/domain error until both the key is valid and the domain is verified.
RESEND_API_KEY=re_your_api_key_here
